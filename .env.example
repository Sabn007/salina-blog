# Strapi CMS
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Optional: API token for draft preview and server-side requests
# STRAPI_API_TOKEN=your-api-token-here

# On-demand revalidation secret (set the same on Strapi webhook)
# REVALIDATION_SECRET=your-random-secret

# Site configuration
NEXT_PUBLIC_SITE_NAME=Salina Journal
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_DESCRIPTION=A premium lifestyle and travel journal — curated stories, destinations, and inspiration for the modern wanderer.

# Google AdSense (optional)
